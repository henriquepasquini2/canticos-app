VITE_SUPABASE_URL=your-supabase-url-here
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here
VITE_GOOGLE_API_KEY=your-google-api-key-here

# Server-side only (used by scripts/migrate-data.ts).
# Do NOT prefix with VITE_ — that would expose it in the client bundle!
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Public repertoire root in Drive (no per-song folder). Use one of:
# VITE_DRIVE_ROOT_FOLDER_URL=https://drive.google.com/drive/folders/YOUR_FOLDER_ID
# VITE_DRIVE_ROOT_FOLDER_ID=YOUR_FOLDER_ID
# If unset, “open Drive” fallbacks point to https://drive.google.com

# Optional: default URLs on the Sync page (local .env only; do not commit secrets)
# VITE_DEFAULT_SHEETS_CSV_URL=https://docs.google.com/spreadsheets/d/.../export?format=csv&gid=...
# VITE_DEFAULT_DRIVE_FOLDER_URL=https://drive.google.com/drive/folders/...
